{
	"name": "npsze",
	"version": "0.0.0",
	"description": "Get npm package size",
	"keywords": [],
	"repository": "https://github.com/hyperz111/npsze.git",
	"license": "MIT",
	"author": "Hyper-Z11 (https://github.com/hyperz111)",
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
