	},
	"dependencies": {
		"filesize": "^11.0.15",
		"semver": "^7.7.4"
	},
	"devDependencies": {
		"@hyperz111/prettier-config": "^1",
		"@hyperz111/tsconfig": "^1",
		"@types/node": "^25.6.0",
		"@types/semver": "^7.7.1",
		"prettier": "^3",
		"typescript": "^6"
	},
	"packageManager": "pnpm@10.15.0"
}
